# Managed by Ansible - do not edit manually
# Customer: {{ vk_customer_name }}
# Tier: {{ vk_tier }}

services:
  api:
    image: {{ vk_image_registry }}/api:{{ vk_image_tag }}
    restart: unless-stopped
    env_file: .env
    networks:
      - vaultkeeper
    depends_on:
      postgres:
        condition: service_healthy
      minio:
        condition: service_healthy
      meilisearch:
        condition: service_healthy
      keycloak:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:8080/health"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: {{ vk_resource_limits[vk_tier].api_memory }}
          cpus: "{{ vk_resource_limits[vk_tier].api_cpus }}"

  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - vaultkeeper
    depends_on:
      api:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 128M
          cpus: "0.5"

  postgres:
    image: postgres:16-alpine
    container_name: vk-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: vaultkeeper
      POSTGRES_USER: {{ vk_postgres_user }}
      POSTGRES_PASSWORD: {{ vk_postgres_password }}
    volumes:
      - pg_data:/var/lib/postgresql/data
    networks:
      - vaultkeeper
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vk_postgres_user }} -d vaultkeeper"]
      interval: 5s
      timeout: 5s
      retries: 10
    deploy:
      resources:
        limits:
          memory: {{ vk_resource_limits[vk_tier].postgres_memory }}
          cpus: "{{ vk_resource_limits[vk_tier].postgres_cpus }}"

  minio:
    image: minio/minio:latest
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: {{ vk_minio_access_key }}
      MINIO_ROOT_PASSWORD: {{ vk_minio_secret_key }}
    volumes:
      - minio_data:/data
    networks:
      - vaultkeeper
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: {{ vk_resource_limits[vk_tier].minio_memory }}
          cpus: "{{ vk_resource_limits[vk_tier].minio_cpus }}"

  keycloak:
    image: quay.io/keycloak/keycloak:24.0
    restart: unless-stopped
    command: start --import-realm
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/vaultkeeper
      KC_DB_USERNAME: {{ vk_postgres_user }}
      KC_DB_PASSWORD: {{ vk_postgres_password }}
      KC_HOSTNAME_STRICT: "false"
      KC_HTTP_ENABLED: "true"
      KEYCLOAK_ADMIN: {{ vk_keycloak_admin_user }}
      KEYCLOAK_ADMIN_PASSWORD: {{ vk_keycloak_admin_password }}
    volumes:
      - keycloak_data:/opt/keycloak/data
    networks:
      - vaultkeeper
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "exec 3<>/dev/tcp/localhost/8080 && echo -e 'GET /health/ready HTTP/1.1\\r\\nHost: localhost\\r\\nConnection: close\\r\\n\\r\\n' >&3 && cat <&3 | grep -q '200'"]
      interval: 15s
      timeout: 10s
      retries: 10
      start_period: 60s
    deploy:
      resources:
        limits:
          memory: {{ vk_resource_limits[vk_tier].keycloak_memory }}
          cpus: "{{ vk_resource_limits[vk_tier].keycloak_cpus }}"

  meilisearch:
    image: getmeili/meilisearch:v1.7
    restart: unless-stopped
    environment:
      MEILI_MASTER_KEY: {{ vk_meilisearch_api_key }}
      MEILI_ENV: production
    volumes:
      - meili_data:/meili_data
    networks:
      - vaultkeeper
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:7700/health"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: {{ vk_resource_limits[vk_tier].meilisearch_memory }}
          cpus: "{{ vk_resource_limits[vk_tier].meilisearch_cpus }}"

volumes:
  pg_data:
  minio_data:
  keycloak_data:
  meili_data:
  caddy_data:
  caddy_config:

networks:
  vaultkeeper:
    driver: bridge

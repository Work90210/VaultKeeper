# =============================================================================
# VaultKeeper Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_URL=https://vaultkeeper.eu          # Required: Public URL of the application
APP_ENV=development                      # Required: development | staging | production
LOG_LEVEL=info                           # Optional: debug | info | warn | error (default: info)
SERVER_PORT=8080                         # Optional: HTTP server port (default: 8080)
CORS_ORIGINS=                            # Optional: Comma-separated CORS origins (Caddy handles in prod)

# --- PostgreSQL ---
DATABASE_URL=postgres://vaultkeeper:CHANGE_ME@postgres:5432/vaultkeeper?sslmode=disable
POSTGRES_USER=vaultkeeper                # Used by Docker Compose
POSTGRES_PASSWORD=CHANGE_ME              # CHANGE ME - Used by Docker Compose

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=minio:9000               # Required: MinIO server endpoint
MINIO_ACCESS_KEY=CHANGE_ME              # Required: MinIO access key
MINIO_SECRET_KEY=CHANGE_ME              # Required: MinIO secret key (min 8 chars)
MINIO_BUCKET=evidence                    # Required: Default bucket name
MINIO_USE_SSL=false                      # Optional: Use SSL for MinIO (default: true, false for local dev)

# --- Keycloak (Authentication) ---
KEYCLOAK_URL=http://keycloak:8080        # Required: Keycloak server URL
KEYCLOAK_REALM=vaultkeeper               # Required: Keycloak realm name
KEYCLOAK_CLIENT_ID=vaultkeeper-api       # Required: OIDC client ID for Go API
KEYCLOAK_CLIENT_SECRET=CHANGE_ME         # Required: OIDC client secret for web frontend
KEYCLOAK_ADMIN=admin                     # Used by Docker Compose
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME        # CHANGE ME - Used by Docker Compose

# --- Next.js Auth ---
NEXTAUTH_SECRET=CHANGE_ME                # Required: 32-byte random secret for session signing
NEXTAUTH_URL=http://localhost:3000       # Required: Public URL of the Next.js app

# --- RFC 3161 Trusted Timestamping ---
TSA_ENABLED=true                         # Optional: Enable TSA (default: true)
TSA_URL=http://timestamp.digicert.com    # Required when TSA_ENABLED=true

# --- Meilisearch (Full-text Search) ---
MEILISEARCH_URL=http://meilisearch:7700  # Required: Meilisearch server URL
MEILISEARCH_API_KEY=CHANGE_ME            # Required: Meilisearch master key

# --- SMTP (Email Notifications) ---
# All SMTP fields are optional, but if any are set, all must be set
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                          # Optional: SMTP port (default: 587)
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@vaultkeeper.eu

# --- Encryption ---
# Required in production, optional in development
# WITNESS_ENCRYPTION_KEY=                # 32-byte hex key for witness identity encryption (Sprint 7)
# MASTER_ENCRYPTION_KEY=                 # 32-byte hex key for per-case encryption (Sprint 18)

# --- Session Management ---
MAX_CONCURRENT_SESSIONS=3                # Optional: Max sessions per user (default: 3)

# --- Case Reference Validation ---
# CASE_REFERENCE_REGEX=^[A-Z]+-[A-Z]+-\d{4}(-\d+)?$  # Optional: Regex for case reference codes

# --- Upload Limits ---
MAX_UPLOAD_SIZE=10737418240              # Optional: Max upload size in bytes (default: 10GB)

# --- Backup ---
# BACKUP_DESTINATION=                    # Optional: Backup destination path
# BACKUP_ENC_KEY=                        # Required when BACKUP_DESTINATION is set

# --- Archive Storage ---
# ARCHIVE_STORAGE_BUCKET=               # Optional: Separate MinIO bucket for cold storage
# ARCHIVE_STORAGE_PATH=                 # Optional: SFTP path for archived case files
